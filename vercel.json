{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/start-registration", "destination": "/start-registration.html" },
    { "source": "/blogs/:slug", "destination": "/blogs/:slug.html" }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/image/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
