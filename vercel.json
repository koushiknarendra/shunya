{
  "buildCommand": "node generate-sitemap.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/_next/image", "destination": "/api/next-image" },
    { "source": "/start-registration", "destination": "/start-registration.html" },
    { "source": "/blogs/:slug", "destination": "/blogs/:slug.html" },
    { "source": "/thank-you-ca", "destination": "/thank-you-ca.html" }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/image/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    }
  ]
}
